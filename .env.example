# Copy to .env.local and fill in. These are read by Vite at build time.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional. Base URL used to build the customer disclaimer signing link
# (.../disclaimer/{token}). Defaults to the app's own origin when unset, so
# set this to your deployed domain in production, e.g. https://pulse.renew-it.co.za
VITE_DISCLAIMER_BASE_URL=
